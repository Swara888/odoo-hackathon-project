generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id               Int      @id @default(autoincrement())
  name             String
  country          String
  default_currency String   @db.VarChar(3)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  users          User[]
  expenses       Expense[]
  approval_rules ApprovalRule[]
}

model User {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String   @unique
  password_hash       String
  role                UserRole
  company_id          Int
  manager_id          Int?
  is_manager_approver Boolean  @default(false)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  manager User?   @relation("manages", fields: [manager_id], references: [id], onDelete: SetNull)
  reports User[]  @relation("manages")

  expenses          Expense[]
  expense_approvals ExpenseApproval[]
  rule_approvers    RuleApprover[]
}

enum UserRole {
  Admin
  Manager
  Employee
}

model Expense {
  id                         Int           @id @default(autoincrement())
  employee_id                Int
  company_id                 Int
  amount                     Decimal
  currency                   String        @db.VarChar(3)
  amount_in_company_currency Decimal
  category                   String
  description                String?
  date                       DateTime
  status                     ExpenseStatus @default(Pending)
  current_step               Int           @default(0)
  created_at                 DateTime      @default(now())
  updated_at                 DateTime      @updatedAt

  employee User    @relation(fields: [employee_id], references: [id])
  company  Company @relation(fields: [company_id], references: [id])

  approvals ExpenseApproval[]
  receipts  ExpenseReceipt[]

  @@index([employee_id])
  @@index([status])
  @@index([company_id])
}

enum ExpenseStatus {
  Pending
  Approved
  Rejected
}

model ExpenseApproval {
  id              Int           @id @default(autoincrement())
  expense_id      Int
  approver_id     Int
  sequence_number Int
  status          ExpenseStatus @default(Pending)
  comments        String?
  created_at      DateTime      @default(now())
  updated_at      DateTime      @updatedAt

  expense  Expense @relation(fields: [expense_id], references: [id])
  approver User    @relation(fields: [approver_id], references: [id])

  @@index([expense_id])
}

model ApprovalRule {
  id                   Int      @id @default(autoincrement())
  company_id           Int
  name                 String
  rule_type            RuleType
  min_amount           Decimal?
  max_amount           Decimal?
  percentage_threshold Int?
  specific_approver_id Int?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  company   Company        @relation(fields: [company_id], references: [id])
  approvers RuleApprover[]
}

enum RuleType {
  Sequential
  Percentage
  Specific
  Hybrid
}

model RuleApprover {
  id          Int @id @default(autoincrement())
  rule_id     Int
  approver_id Int
  sequence    Int

  rule     ApprovalRule @relation(fields: [rule_id], references: [id])
  approver User         @relation(fields: [approver_id], references: [id])

  @@unique([rule_id, sequence])
}

model ExpenseReceipt {
  id          Int      @id @default(autoincrement())
  expense_id  Int
  receipt_url String
  ocr_data    Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  expense Expense @relation(fields: [expense_id], references: [id])
}
